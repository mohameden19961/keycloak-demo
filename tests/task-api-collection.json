    {
      "name": "9. Admin List All Tasks",
      "request": {
        "method": "GET",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}" }]
        },
        "url": {
          "raw": "{{app_url}}/api/admin/tasks",
          "host": ["{{app_url}}"],
          "path": ["api", "admin", "tasks"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));",
              "pm.test('Admin has MANAGE authority', () => pm.expect(pm.response.code).to.eql(200));"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "10. Delete Own Task",
      "request": {
        "method": "DELETE",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}" }]
        },
        "url": {
          "raw": "{{app_url}}/api/tasks/{{task_id}}",
          "host": ["{{app_url}}"],
          "path": ["api", "tasks", "{{task_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "response": []
    }
  ],
