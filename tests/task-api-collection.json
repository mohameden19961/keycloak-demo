{
  "info": {
    "_postman_id": "ccb58144-d489-4f98-aa6a-4c0c26f7bab4",
    "name": "Task API",
    "description": "Collection Postman pour tester l'API complète : auth (Keycloak), CRUD tâches, admin",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "client_id", "value": "task-api" },
            { "key": "grant_type", "value": "password" },
            { "key": "username", "value": "{{username}}" },
            { "key": "password", "value": "{{password}}" }
          ]
        },
        "url": {
          "raw": "{{keycloak_url}}/realms/Taks/protocol/openid-connect/token",
          "host": ["{{keycloak_url}}"],
          "path": ["realms", "Taks", "protocol", "openid-connect", "token"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "pm.collectionVariables.set('access_token', data.access_token);",
              "pm.collectionVariables.set('refresh_token', data.refresh_token);",
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "2. Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{app_url}}/api/public/health",
          "host": ["{{app_url}}"],
          "path": ["api", "public", "health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Body is ok', () => pm.response.to.have.body('ok'));"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "3. Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{new_username}}\",\n  \"email\": \"{{new_email}}\",\n  \"password\": \"{{new_password}}\"\n}"
        },
        "url": {
          "raw": "{{app_url}}/api/auth/register",
          "host": ["{{app_url}}"],
          "path": ["api", "auth", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "4. Create Task",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}" }]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Apprendre Keycloak\"\n}"
        },
        "url": {
          "raw": "{{app_url}}/api/tasks",
          "host": ["{{app_url}}"],
          "path": ["api", "tasks"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "pm.collectionVariables.set('task_id', data.id);",
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has id', () => pm.expect(data.id).to.exist);"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "5. Get My Tasks",
      "request": {
        "method": "GET",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}" }]
        },
        "url": {
          "raw": "{{app_url}}/api/tasks",
          "host": ["{{app_url}}"],
          "path": ["api", "tasks"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "6. Validation Error (empty title)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}" }]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"\"\n}"
        },
        "url": {
          "raw": "{{app_url}}/api/tasks",
          "host": ["{{app_url}}"],
          "path": ["api", "tasks"]
